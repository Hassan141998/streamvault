# Copy this file → rename to .env.local → fill in your values

# 1. FREE from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# 2. FREE from: https://neon.tech (paste your connection string)
DATABASE_URL=

# 3. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# 4. Your URL (localhost for dev, your vercel URL for production)
NEXTAUTH_URL=http://localhost:3000

# 5. Optional: Google OAuth from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
